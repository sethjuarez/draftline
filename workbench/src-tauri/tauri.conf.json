{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Draftline Workbench",
  "version": "0.1.0",
  "identifier": "dev.draftline.workbench",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Draftline Workbench",
        "width": 1280,
        "height": 900,
        "minWidth": 960,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
